{
  "name": "itrf",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "start-server-and-test 'vite --host --port 5173' 5173 'cypress open --e2e --browser electron --config baseUrl=http://localhost:5173/itrf/ --env environment=local'",
    "test:e2e:headless": "start-server-and-test 'vite --host --port 5173' 5173 'cypress run --config baseUrl=http://localhost:5173/itrf/ --env environment=local'",
    "test:e2e:dev": "cypress open --e2e --browser electron --config baseUrl=https://dev.my.gov.bc.ca/itrf/ --env environment=dev",
    "test:e2e:test": "cypress open --e2e --browser electron --config baseUrl=https://test.my.gov.bc.ca/itrf/ --env environment=test",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore --fix src",
    "format": "prettier .  --write",
    "precommit": "lint-staged",
    "prepare": "cd .. && husky itrf/.husky"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.2.36",
    "@fortawesome/free-solid-svg-icons": "^5.15.4",
    "@fortawesome/vue-fontawesome": "^3.0.0-5",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "axios": "^1.6.2",
    "date-fns": "^4.4.0",
    "maska": "^1.5.0",
    "uuid": "^14.0.1",
    "vue": "^3.5.39",
    "vue-router": "^4.2.5",
    "vuex": "^4.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "cypress": "^13.6.6",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^2.15.1",
    "eslint-plugin-vue": "^9.22.0",
    "husky": "^9.0.11",
    "jsdom": "^23.0.1",
    "lint-staged": "^15.2.2",
    "lodash": "^4.17.21",
    "prettier": "3.2.5",
    "sass": "^1.69.5",
    "start-server-and-test": "^3.0.11",
    "vite": "^8.1.2",
    "vitest": "^1.1.0"
  },
  "lint-staged": {
    "src/*/*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm precommit"
    }
  }
}
