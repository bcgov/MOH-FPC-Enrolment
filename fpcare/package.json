    "moment": "^2.29.4",
    "mygovbc-bootstrap-theme": "^0.4.0",
    "ngx-bootstrap": "^19.0.2",
    "ngx-mask": "^19.0.7",
    "ngx-mydatepicker": "^2.4.9",
    "pdfjs-dist": "~2.11.338",
