{
  "name": "fpcare",
  "version": "4.2.3",
  "description": "FPCare Service Provider Web App",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bcgov/MOH-FPC-Enrolment.git"
  },
  "homepage": "https://my.gov.bc.ca/fpcare",
  "main": "server.js",
  "scripts": {
    "ng": "ng",
    "start": "npm run dev",
    "dev": "ng serve --host=\"0.0.0.0\" -o",
    "dev-build": "ng build",
    "prebuild": "node ./src/version.js",
    "build": "ng build --prod",
    "test": "ng test",
    "test:coverage": "ng test --watch=false --code-coverage --browsers=ChromeHeadless",
    "version": "node ./src/version.js",
    "postversion": "git add . && git commit -m \"chore: commit version file\"",
    "test-version": "npm version minor -m 'TEST build: %s'",
    "prod-version": "npm version major -m 'PROD build: %s'",
    "push-version": "git push --follow-tags",
    "lint": "eslint src --ext .ts,.html"
  },
  "dependencies": {
    "@angular/animations": "~19.2.20",
