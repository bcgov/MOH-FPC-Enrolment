    "@angular/platform-browser-dynamic": "~19.2.20",
    "@angular/router": "~19.2.20",
    "@ng-select/ng-select": "^2.16.3",
    "angular2-uuid": "^1.1.1",
    "blueimp-load-image": "^2.20.1",
